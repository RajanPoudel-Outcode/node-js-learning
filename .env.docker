# Docker Environment Configuration
NODE_ENV=development
PORT=3000

# MongoDB connection string for Docker Compose
MONGO_URL=mongodb://mongo:27017/nodeLearning?retryWrites=true&w=majority

# Prisma Database URL
DATABASE_URL=mongodb://mongo:27017/nodeLearning?replicaSet=rs0&retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=passwordKey

# Frontend URL
FRONTEND_URL=http://localhost:3001
