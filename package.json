{
  "name": "ecommerce-api-optimized",
  "version": "2.0.0",
  "description": "Feature-based Node.js TypeScript E-commerce API with advanced decorators",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/index.ts",
    "dev:watch": "nodemon --watch src --ext ts --exec ts-node -r tsconfig-paths/register src/index.ts",
    "dev:features": "nodemon --watch src/features --ext ts --exec ts-node -r tsconfig-paths/register src/index.ts",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "type-check": "tsc --noEmit",
    "test": "echo \"Tests will be implemented\" && exit 0",
    "lint": "echo \"Linting will be implemented\" && exit 0"
  },
  "author": "Rajan Paudel",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "http": "^0.0.1-security",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^6.7.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.3",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
